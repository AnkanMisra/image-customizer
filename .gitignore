# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Rust compiled output (regenerated by `cargo build`)
rust-processor/target/

# ONNX Runtime WASM binaries (regenerated by `bun run setup:ort` / postinstall)
public/ort-wasm-simd-threaded*
public/ort.webgpu.min.js
public/ort.all.min.js

# AI model binaries (downloaded separately, too large for git)
public/models/*.onnx
